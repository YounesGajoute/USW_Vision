# Copy to backend/.env on the vision Pi. Values must match the master app.
#
# Master backend/.env (reachable IP — see docs/MASTER_VISION_CONNECTIVITY.md):
#   VISION_URL=http://192.168.10.2:5000
#   VISION_REMOTE_KEY=<same secret as VISION_REMOTE_API_KEY below>
#
# Vision Pi wired LAN (Option A): sudo ./scripts/configure_vision_lan_eth.sh
# Current WiFi example: 192.168.100.121 — only works if master can route there.

VISION_REMOTE_API_KEY="your-shared-secret"
VISION_SOCKETIO_AUTH_MODE=inherit
VISION_SLAVE_REQUIRE_REMOTE_API_KEY=1

# Optional production flags:
# VISION_SLAVE_REQUIRE_HARDWARE=1
# VISION_ALLOW_CAMERA_TEST_PATTERN=0
