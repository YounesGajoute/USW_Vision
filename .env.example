# Inspection transport on run page: rest (default) | ws | rest-with-ws-fallback
NEXT_PUBLIC_INSPECTION_TRANSPORT=rest

# ── Master app (US Machine) — backend/.env on master, NOT on vision Pi ───────
# Pick an IP the master can ping (see docs/MASTER_VISION_CONNECTIVITY.md):
#   Option A (LAN):  VISION_URL=http://192.168.10.2:5000
#   Option B (WiFi):   VISION_URL=http://192.168.100.121:5000
#   Option C (TS):     VISION_URL=http://100.110.239.22:5000
# Master: VISION_REMOTE_KEY=<secret>  (no /api suffix on VISION_URL)
# Master: unset VISION_SLAVE_URL  (never http://127.0.0.1:5000 on the master)
#
# Vision Pi (slave): put the SAME secret in backend/.env:
#   VISION_REMOTE_API_KEY=<same as master VISION_REMOTE_KEY>
#   VISION_SOCKETIO_AUTH_MODE=inherit
# See backend/.env.slave.example

# Optional: browser on vision Pi when using Socket.IO with inherit auth
# NEXT_PUBLIC_VISION_SOCKETIO_KEY=<same as VISION_REMOTE_API_KEY>

# Optional: lock local /api/* (programs, inspection, gpio) — separate from remote key
# VISION_LOCAL_API_KEY=
